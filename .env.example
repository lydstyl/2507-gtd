# ─── Base de données ───────────────────────────────────────────────────────────
# Mot de passe PostgreSQL (utilisé par le container Docker)
DB_PASSWORD=change_me_strong_password

# URL de connexion pour le développement local (même mot de passe que DB_PASSWORD ci-dessus)
DATABASE_URL=postgresql://gtd_user:change_me_strong_password@localhost:5432/gtd_production

# ─── Application ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_very_long_random_string_at_least_32_chars
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# ─── Chatbot LLM ───────────────────────────────────────────────────────────────
# Provider : anthropic | openai | openrouter
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_MODEL=    # optionnel, utilise le modèle par défaut du provider
