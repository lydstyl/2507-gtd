# Docker Compose environment variables
# Copy this file to .env and fill in the values

# Database password (used by both postgres container and backend DATABASE_URL)
DB_PASSWORD=change_me_use_a_strong_password

# JWT signing secret — use a long random string in production
JWT_SECRET=change_me_very_long_random_string_at_least_32_chars

# Frontend origin(s) allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost

# LLM provider for the chatbot: anthropic | openai | openrouter
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_MODEL=                    # optional, uses provider default
